//exemplo do while
//mesmo que o numero de usuarios seja menor que 71, o loop vai rodar pelo menos uma vez,
//  porque a condicao de parada e verificada depois da execucao do bloco de codigo.
let numberUser = 2
do{
    console.log("Numero de usuarios" + numberUser)
    numberUser++ //esse incremento e igual a numberUser = numberUser + 1
}while(numberUser < 71)//conta ate 70


//com string
let nameUser = "Maria"
let i = 0
do{
    console.log(nameUser[i]) //imprime cada letra da string
    i++
}while(i < nameUser.length) //conta ate o numero de caracteres da string


//while loop 
let numberDev = 2
while(numberDev < 21){ //conta ate 20(condicao de parada)
    console.log("Numero de devs" + numberDev)
    numberDev++ //incremento para evitar loop infinito
    //mesma forma de estrutura com string
}
//impotante usar if depois de algum loop, para dar uma condição de verdadeiro ou falso,
// para evitar que o loop rode infinitamente, caso a condição de parada nunca seja alcançada.

//while com if
let numberDev2 = 2
while(numberDev2 <= 21) {
    if(numberDev2 % 4 === 0){ //condicao para imprimir apenas os numeros divisiveis por 4
        console.log("Numero de devs" + numberDev2)
    }
    numberDev2++ //incremento para evitar loop infinito
}


//for loops 
