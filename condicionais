//operador ternario
const age = 88
age >= 18 ? console.log("de maior") : console.log("de menor")//o operador ternário é uma forma concisa de escrever uma expressão condicional,
//  onde a expressão antes do ponto de interrogação (?) é a condição a ser avaliada,
//  a expressão entre o ponto de interrogação e os dois pontos (:) é o valor retornado se a condição for verdadeira,
//  e a expressão após os dois pontos é o valor retornado se a condição for falsa.


//função retornando um valor usando operador ternario 
const somaMultiplica = (valor) => {
    return valor >= 18 ? valor + valor : valor * valor //se for maior que 18 soma, se não multiplica
}

//mesma função usando if...else
    const somaMultiplica = function(valor) {
        if (valor >= 18) {
            return valor + valor
        } else {
            return valor * valor
        }
    }//ambas as funções fazem a mesma coisa, mas a versão com operador ternário é mais concisa e pode ser mais fácil de ler em casos simples.
