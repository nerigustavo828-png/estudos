//objetos e uma coleção de dados relacionados, que podem ser propriedades e métodos.
//inicialização de um objeto new Object() ou {}, Obeject.creat(), ou usando  a forma literal

//exemplo de objeto literal
const objeto = {
    prop1: function() {
        console.log("Olá, sou a prop1");
    }//voce pode usar uma função dentro de um obejto, mas a prop se torna um metodo
}

//dot notation (notação de ponto )
//acessar ou declarar uma nova propriedade ou metodo
//declarando um objeto de forma literal 
const dotNotation = {
    prop1: "Sou uma propriedade que sera acessada usando o dot notation",
    metodo: function () {
        return "Sou um retorno de uma função(metodo) ou seja uma função dentro de um objeto"
    }
}
//acessando a propriedade e o metodo
console.log( dotNotation.prop1 )
console.log( dotNotation.metodo() )

//declarando novos metodo e propriedades
dotNotation.prop2 = "Sou uma nova propriedade"
dotNotation.metodo2 = () => { //usando arrow function para criar um novo metodo
    return "Sou um novo metodo criado usando a notação de ponto"
}
console.log( dotNotation.prop2 )
console.log( dotNotation.metodo2() )

//bracket notation (notação de colchetes)
const bracketNotation = {
    prop1: "Sou uma propriedade que sera acessada usando o bracket notation",
    metodo: function () {
        return "Sou um retorno de uma função(metodo) ou seja uma função dentro de um objeto"
    }
}
//acessando a propriedade e o metodo
console.log( bracketNotation["prop1"] )
console.log( bracketNotation["metodo"]() )


//declarando novos metodo e propriedades
bracketNotation["prop2"] = "Sou uma nova propriedade"
bracketNotation["metodo2"] = () => { //usando arrow function para criar um novo metodo
    return "Sou um novo metodo criado usando a notação de colchetes"
}
console.log( bracketNotation["prop2"] )
console.log( bracketNotation["metodo2"]() )
//propriedade e estatica e metodo nao e estatica mas tem uma ação exemplo o return
